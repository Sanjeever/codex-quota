{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "composite": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "target": "ES2022",
    "lib": ["ES2022", "DOM"],
    "types": ["node"],
    "outDir": "dist-types/node",
    "skipLibCheck": true
  },
  "include": [
    "vite.config.ts",
    "scripts/**/*.mjs"
  ]
}
