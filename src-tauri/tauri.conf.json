{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Codex Quota",
  "version": "1.1.2",
  "identifier": "com.sanjeever.codex-quota",
  "build": {
    "beforeDevCommand": "pnpm generate:icons && vite --host 127.0.0.1",
    "beforeBuildCommand": "pnpm generate:icons && vite build",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "dmg", "app"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "../build/assets/tray-normal.png",
      "../build/assets/tray-error.png"
    ],
    "windows": {
      "nsis": {
        "displayLanguageSelector": false,
        "installerIcon": "icons/icon.ico"
      }
    },
    "macOS": {
      "minimumSystemVersion": "10.15"
    }
  }
}
